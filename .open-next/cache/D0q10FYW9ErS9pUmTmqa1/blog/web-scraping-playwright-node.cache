ldren\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":\\\"true\\\",\\\"className\\\":\\\"pointer-events-none absolute h-3 w-3 border-hud/80 left-[-1px] top-[-1px] border-l-2 border-t-2\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":\\\"true\\\",\\\"className\\\":\\\"pointer-events-none absolute h-3 w-3 border-hud/80 right-[-1px] top-[-1px] border-r-2 border-t-2\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":\\\"true\\\",\\\"className\\\":\\\"pointer-events-none absolute h-3 w-3 border-hud/80 bottom-[-1px] left-[-1px] border-b-2 border-l-2\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":\\\"true\\\",\\\"className\\\":\\\"pointer-events-none absolute h-3 w-3 border-hud/80 bottom-[-1px] right-[-1px] border-b-2 border-r-2\\\"}],[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"flex items-center justify-between gap-4 border-b border-ctp-surface1/60 px-4 py-2.5 sm:px-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"font-mono text-xs font-semibold uppercase tracking-[0.3em] text-hud hud-glow sm:text-sm\\\",\\\"children\\\":\\\"DECODED TRANSMISSION\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"shrink-0 font-mono text-[10px] uppercase tracking-[0.25em] text-ctp-overlay0\\\",\\\"children\\\":\\\"2024-08-24 · 8 MIN READ\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"p-4 sm:p-6 \\\",\\\"children\\\":[[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"font-mono text-2xl font-bold leading-tight text-ctp-text hud-glow sm:text-3xl\\\",\\\"children\\\":\\\"Web Scraping with Playwright and Node.js: A Practical Tutorials\\\"}],[\\\"$\\\",\\\"article\\\",null,{\\\"className\\\":\\\"prose prose-invert mt-6 max-w-none prose-headings:font-mono prose-a:text-ctp-sapphire prose-strong:text-ctp-text prose-code:text-hud\\\",\\\"children\\\":\\\"$L11\\\"}]]}]\"])</script><script>self.__next_f.push([1,\"]}]]}]\\nd:[[\\\"$\\\",\\\"meta\\\",\\\"0\\\",{\\\"name\\\":\\\"viewport\\\",\\\"content\\\":\\\"width=device-width, initial-scale=1\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"charSet\\\":\\\"utf-8\\\"}],[\\\"$\\\",\\\"title\\\",\\\"2\\\",{\\\"children\\\":\\\"abmoallim\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"3\\\",{\\\"name\\\":\\\"description\\\",\\\"content\\\":\\\"Personal Portfolio of Abdihamid Moallim\\\"}],[\\\"$\\\",\\\"link\\\",\\\"4\\\",{\\\"rel\\\":\\\"icon\\\",\\\"href\\\":\\\"/favicon.ico\\\",\\\"type\\\":\\\"image/x-icon\\\",\\\"sizes\\\":\\\"150x150\\\"}],[\\\"$\\\",\\\"link\\\",\\\"5\\\",{\\\"rel\\\":\\\"icon\\\",\\\"href\\\":\\\"/icon.png?02db24294edd3330\\\",\\\"type\\\":\\\"image/png\\\",\\\"sizes\\\":\\\"150x150\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"6\\\",{\\\"name\\\":\\\"next-size-adjust\\\"}]]\\n5:null\\n\"])</script><script>self.__next_f.push([1,\"11:[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"img\\\",null,{\\\"src\\\":\\\"/imgs/web-scraping.png\\\",\\\"alt\\\":\\\"alt text\\\"}],\\\"\\\\nWeb scraping is an essential technique in a developer's toolkit, allowing the extraction of data from websites for various purposes, such as data analysis, monitoring, and automation. Playwright, paired with Node.js, provides a powerful and flexible framework for web scraping, especially when dealing with modern, dynamic websites. In this tutorial, we'll walk you through setting up a web scraping project with Playwright and cover essential aspects of scraping, from basic setups to handling more complex scenarios.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"1. Setting Up Your Environment\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"To begin, you'll need to have Node.js installed on your machine. Node.js is a JavaScript runtime that allows you to run JavaScript code outside of a web browser. Once you have Node.js installed, you can create a new project directory and initialize a Node.js project:\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"pre\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"code\\\",null,{\\\"className\\\":\\\"language-bash\\\",\\\"children\\\":\\\"mkdir playwright-scraper\\\\ncd playwright-scraper\\\\nnpm init -y\\\\nnpm install playwright\\\\n\\\"}]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"The commands above will create a new directory, initialize a Node.js project, and install Playwright. Playwright is a Node.js library to automate Chromium, Firefox, and WebKit with a single API. It is ideal for scraping tasks because of its ability to handle complex web interactions, including those involving JavaScript and dynamic content.\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"2. Writing Your First Playwright Script\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"Let's start by writing a simple script that launches a browser, navigates to a webpage, and retrieves the page title. Create a new file named \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"scraper.js\\\"}],\\\" and add the following code:\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"pre\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"code\\\",null,{\\\"className\\\":\\\"language-javascript\\\",\\\"children\\\":\\\"const { chromium } = require('playwright');\\\\n\\\\n(async () =\\u003e {\\\\n  const browser = await chromium.launch();\\\\n  const page = await browser.newPage();\\\\n  await page.goto('https://example.com');\\\\n  const title = await page.title();\\\\n  console.log(`Title: ${title}`);\\\\n  await browser.close();\\\\n})();\\\\n\\\"}]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"In this script, we use Playwright to launch a Chromium browser, open a new page, navigate to \\\\\\\"\\\",[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"https://example.com\\\",\\\"children\\\":\\\"https://example.com\\\"}],\\\"\\\\\\\", and print the page's title to the console. Finally, the browser is closed. This is a basic example, but it showcases the simplicity and power of Playwright for web scraping.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"3. Extracting Data from a Web Page\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"Web scraping often involves extracting specific pieces of data from a webpage. Let's modify our script to extract the headlines from the Hacker News homepage. Update your \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"scraper.js\\\"}],\\\" file with the following code:\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"pre\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"code\\\",null,{\\\"className\\\":\\\"language-javascript\\\",\\\"children\\\":\\\"await page.goto('https://news.ycombinator.com/');\\\\nconst headlines = await page.$$eval('.storylink', links =\\u003e links.map(link =\\u003e link.textContent));\\\\nconsole.log(headlines);\\\\n\\\"}]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"Here, we're using the \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"$$$eval\\\"}],\\\" function, which allows us to select all elements matching a CSS selector (\\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\".storylink\\\"}],\\\" in this case) and run a function on them. The function extracts the text content of each element and returns it as an array of strings.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"4. Handling Dynamic Content\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"Modern websites often load content dynamically using JavaScript, which means that the content may not be available immediately when the page loads. Playwright's \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"waitForSelector\\\"}],\\\" method can be used to wait for specific elements to appear before interacting with them:\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"pre\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"code\\\",null,{\\\"className\\\":\\\"language-javascript\\\",\\\"children\\\":\\\"await page.goto('https://example.com');\\\\nawait page.waitForSelector('.dynamic-content');\\\\nconst content = await page.$eval('.dynamic-content', el =\\u003e el.textContent);\\\\nconsole.log(content);\\\\n\\\"}]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"In this example, we wait for an element with the class \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\".dynamic-content\\\"}],\\\" to appear on the page before extracting its text content.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"5. Managing Authentication\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Some websites require users to log in before accessing certain data. Playwright can handle this by filling out login forms and submitting them:\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"pre\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"code\\\",null,{\\\"className\\\":\\\"language-javascript\\\",\\\"children\\\":\\\"await page.goto('https://example.com/login');\\\\nawait page.fill('#username', 'yourUsername');\\\\nawait page.fill('#password', 'yourPassword');\\\\nawait page.click('#loginButton');\\\\n\\\"}]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"This script navigates to a login page, fills out the username and password fields, and clicks the login button. Playwright will manage the session automatically, allowing you to scrape protected content.\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"6. Saving Scraped Data\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"Once you've extracted data from a webpage, you'll often want to save it for later use. You can save data to a JSON file using Node.js's built-in \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"fs\\\"}],\\\" module:\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"pre\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"code\\\",null,{\\\"className\\\":\\\"language-javascript\\\",\\\"children\\\":\\\"const fs = require('fs');\\\\nfs.writeFileSync('headlines.json', JSON.stringify(headlines, null, 2));\\\\n\\\"}]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"This code saves the \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"headlines\\\"}],\\\" array to a file named \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"headlines.json\\\"}],\\\", formatting the JSON with an indentation of 2 spaces.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"7. Best Practices for Web Scraping\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"When scraping websites, it's important to follow best practices to avoid legal issues or being blocked by the website. Here are some tips:\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":[\\\"Respect \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"robots.txt\\\"}],\\\":\\\"]}],\\\" Always check the site's \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"robots.txt\\\"}],\\\" file to see what parts of the site you're allowed to scrape.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Rate Limiting:\\\"}],\\\" Introduce delays between requests to avoid overwhelming the server.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Error Handling:\\\"}],\\\" Implement error handling to manage issues such as network errors or unexpected changes in the webpage structure.\\\"]}],\\\"\\\\n\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"Conclusion\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Web scraping with Playwright and Node.js offers a powerful way to collect data from websites, whether they are static or dynamically loaded. With the basics covered in this tutorial, you should be well-equipped to start building your own web scrapers. From handling simple HTML pages to complex, JavaScript-heavy sites requiring authentication, Playwright provides the tools you need to get the job done efficiently.\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Happy scraping!\\\"}]]\\n\"])</script></body></html>","rsc":"3:I[4707,[],\"\"]\n5:I[6423,[],\"\"]\n6:I[8003,[\"310\",\"static/chunks/0e5ce63c-87c8b437464bdc9c.js\",\"676\",\"static/chunks/870fdd6f-da8ed140d788e7c2.js\",\"958\",\"static/chunks/69b09407-d9a7fe10f96f9322.js\",\"37\",\"static/chunks/37-bed021474d23436f.js\",\"972\",\"static/chunks/972-0fea25be27918f94.js\",\"720\",\"static/chunks/720-d558a38c8385dde0.js\",\"363\",\"static/chunks/363-ab827813135a986d.js\",\"185\",\"static/chunks/app/layout-f2485aa61d76c138.js\"],\"\"]\n7:I[9813,[\"310\",\"static/chunks/0e5ce63c-87c8b437464bdc9c.js\",\"676\",\"static/chunks/870fdd6f-da8ed140d788e7c2.js\",\"958\",\"static/chunks/69b09407-d9a7fe10f96f9322.js\",\"37\",\"static/chunks/37-bed021474d23436f.js\",\"972\",\"static/chunks/972-0fea25be27918f94.js\",\"720\",\"static/chunks/720-d558a38c8385dde0.js\",\"363\",\"static/chunks/363-ab827813135a986d.js\",\"185\",\"static/chunks/app/layout-f2485aa61d76c138.js\"],\"default\"]\n8:I[8868,[\"310\",\"static/chunks/0e5ce63c-87c8b437464bdc9c.js\",\"676\",\"static/chunks/870fdd6f-da8ed140d788e7c2.js\",\"958\",\"static/chunks/69b09407-d9a7fe10f96f9322.js\",\"37\",\"static/chunks/37-bed021474d23436f.js\",\"972\",\"static/chunks/972-0fea25be27918f94.js\",\"720\",\"static/chunks/720-d558a38c8385dde0.js\",\"363\",\"static/chunks/363-ab827813135a986d.js\",\"185\",\"static/chunks/app/layout-f2485aa61d76c138.js\"],\"default\"]\n4:[\"slug\",\"web-scraping-playwright-node\",\"d\"]\n0:[\"D0q10FYW9ErS9pUmTmqa1\",[[[\"\",{\"children\":[\"blog\",{\"children\":[[\"slug\",\"web-scraping-playwright-node\",\"d\"],{\"children\":[\"__PAGE__?{\\\"slug\\\":\\\"web-scraping-playwright-node\\\"}\",{}]}]}]},\"$undefined\",\"$undefined\",true],[\"\",{\"children\":[\"blog\",{\"children\":[[\"slug\",\"web-scraping-playwright-node\",\"d\"],{\"children\":