btext0 transition-colors hover:text-hud\",\"children\":\"LinkedIn\"}],[\"$\",\"a\",\"GitHub\",{\"href\":\"https://github.com/abmoallim\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-ctp-subtext0 transition-colors hover:text-hud\",\"children\":\"GitHub\"}],[\"$\",\"a\",\"X\",{\"href\":\"https://x.com/abmoallim\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-ctp-subtext0 transition-colors hover:text-hud\",\"children\":\"X\"}]]}],[\"$\",\"p\",null,{\"children\":\"NEXT.JS + TAILWIND\"}]]}]}]]}],[\"$\",\"$L8\",null,{}],[[\"$\",\"div\",null,{\"className\":\"crt-vignette\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",null,{\"className\":\"crt-overlay\",\"aria-hidden\":\"true\"}]]]}]]}]],null],null],[\"$L9\",null]]]]\na:I[2972,[\"972\",\"static/chunks/972-0fea25be27918f94.js\",\"308\",\"static/chunks/app/blog/%5Bslug%5D/page-75d8f4942794d469.js\"],\"\"]\n2:[\"$\",\"main\",null,{\"className\":\"mx-auto max-w-4xl space-y-6 px-3 pb-8 pt-20 sm:px-6\",\"children\":[[\"$\",\"$La\",null,{\"href\":\"/blog\",\"className\":\"inline-block font-mono text-[11px] uppercase tracking-[0.25em] text-ctp-overlay0 transition-colors hover:text-hud\",\"children\":\"◂ RETURN TO ARCHIVE\"}],[\"$\",\"section\",null,{\"id\":\"$undefined\",\"className\":\"relative border border-ctp-surface1/70 bg-ctp-mantle/70 backdrop-blur \",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":\"true\",\"className\":\"pointer-events-none absolute h-3 w-3 border-hud/80 left-[-1px] top-[-1px] border-l-2 border-t-2\"}],[\"$\",\"span\",null,{\"aria-hidden\":\"true\",\"className\":\"pointer-events-none absolute h-3 w-3 border-hud/80 right-[-1px] top-[-1px] border-r-2 border-t-2\"}],[\"$\",\"span\",null,{\"aria-hidden\":\"true\",\"className\":\"pointer-events-none absolute h-3 w-3 border-hud/80 bottom-[-1px] left-[-1px] border-b-2 border-l-2\"}],[\"$\",\"span\",null,{\"aria-hidden\":\"true\",\"className\":\"pointer-events-none absolute h-3 w-3 border-hud/80 bottom-[-1px] right-[-1px] border-b-2 border-r-2\"}],[\"$\",\"header\",null,{\"className\":\"flex items-center justify-between gap-4 border-b border-ctp-surface1/60 px-4 py-2.5 sm:px-6\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-mono text-xs font-semibold uppercase tracking-[0.3em] text-hud hud-glow sm:text-sm\",\"children\":\"DECODED TRANSMISSION\"}],[\"$\",\"div\",null,{\"className\":\"shrink-0 font-mono text-[10px] uppercase tracking-[0.25em] text-ctp-overlay0\",\"children\":\"2025-12-21 · 3 MIN READ\"}]]}],[\"$\",\"div\",null,{\"className\":\"p-4 sm:p-6 \",\"children\":[[\"$\",\"h1\",null,{\"className\":\"font-mono text-2xl font-bold leading-tight text-ctp-text hud-glow sm:text-3xl\",\"children\":\"2025: What Actually Happened\"}],[\"$\",\"article\",null,{\"className\":\"prose prose-invert mt-6 max-w-none prose-headings:font-mono prose-a:text-ctp-sapphire prose-strong:text-ctp-text prose-code:text-hud\",\"children\":\"$Lb\"}]]}]]}]]}]\n9:[[\"$\",\"meta\",\"0\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}],[\"$\",\"meta\",\"1\",{\"charSet\":\"utf-8\"}],[\"$\",\"title\",\"2\",{\"children\":\"abmoallim\"}],[\"$\",\"meta\",\"3\",{\"name\":\"description\",\"content\":\"Personal Portfolio of Abdihamid Moallim\"}],[\"$\",\"link\",\"4\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\",\"type\":\"image/x-icon\",\"sizes\":\"150x150\"}],[\"$\",\"link\",\"5\",{\"rel\":\"icon\",\"href\":\"/icon.png?02db24294edd3330\",\"type\":\"image/png\",\"sizes\":\"150x150\"}],[\"$\",\"meta\",\"6\",{\"name\":\"next-size-adjust\"}]]\n1:null\nb:[[\"$\",\"h1\",null,{\"children\":\"2025: What Actually Happened\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"At the start of 2025, I had a clear list of goals. Not the loud kind the quiet, personal ones. They came from a year of learning, trying, failing, and slowly understanding myself better.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Now that the year is coming to an end, I want to talk about what actually happened not what looks good on paper, but what stayed.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Learning to Say “No”\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"This one happened. Fully.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I cut a lot of noise from my life this year. Projects, conversations, expectations even people. Not out of arrogance or bitterness, but out of clarity. I learned that saying “yes” to everything was slowly saying “no” to myself.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Life got quieter. And better.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Financial Discipline\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I didn’t suddenly become rich, but I became intentional.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I managed my income more carefully, avoided unnecessary spending, and focused on stability over impulse. That alone reduced a lot of mental stress. Money stopped being something I reacted to and started being something I planned around.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"That shift mattered more than I expected.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"AI Agents (Expectation vs Reality)\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I didn’t go as deep into AI agentics as I thought I would.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"But I also didn’t do nothing.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I built a few agents, experimented, learned the patterns, and understood the limitations. None of them reached production level and I’m okay with that. The learning still happened, just not in the dramatic way I imagined at the start of the year.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":[\"The highlight was the time invested with a friend: we clocked more than 120 focused hours across different agentic projects and we’re currently building \",[\"$\",\"strong\",null,{\"children\":\"Decisionfy\"}],\" together. Sometimes progress is quieter than ambition.\"]}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Lama Tools\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"This was one of the highlights of 2025.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"We delivered seven solid projects, including two AI-enabled semi-ERP systems. Real clients. Real delivery. Real responsibility.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"We may not have hit every financial milestone yet, but Lama Tools moved from “potential” to proven execution and that matters far more in the long run.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Living on My Own Terms\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Alhamdulillah, this one runs deep.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I’ve made peace with who I am, how I work, and what I value. I no longer feel the need to match timelines, expectations, or definitions of success that don’t belong to me.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"That internal peace is something I don’t take lightly.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Content Creation (An Honest Take)\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I tried.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I really did.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"And I realized something important, maybe content creation just isn’t for me or at least not right now. I didn’t enjoy it enough. I didn’t want it badly enough. So I stopped forcing it.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"That felt like growth too.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Small but Meaningful Tech Shifts\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"This year also had its fun, nerdy transitions:\"}],\"\\n\",[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":\"Windows → Linux (Fedora) and I’m genuinely enjoying it\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Cursor → Windsurf\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"OpenAI → Claude\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"pip → uv\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Vercel → Cloudflare\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Chrome → Brave\"}],\"\\n\"]}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Nothing life-changing on its own, but together they reflect a pattern: choosing tools that feel intentional, minimal, and aligned with how I want to work.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"The Biggest Achievement\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"This is the one that outweighs everything else.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"With the help of my sisters and cousin, I managed to move my family from Mogadishu to Kenya.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"No project, no revenue milestone, no technical win comes close to that.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"It was stressful. Heavy. Expensive. Emotional. But it was worth it.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Alhamdulillah.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"One More Thing\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I also spent time learning day trading in a halal way. Not chasing hype, but understanding markets, discipline, risk, and patience. Whether it becomes a long-term path or not, the learning itself has already paid off.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"2025 wasn’t flashy.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"It wasn’t viral.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"It wasn’t loud.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"But it was foundational.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"And I’m walking into the next year calmer, clearer, and more grounded than I’ve ever been.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"That’s enough for now.\"}]]\n"}