f\":\"/blog\",\"className\":\"inline-block font-mono text-xs uppercase tracking-[0.2em] text-ink/50 transition-colors hover:text-clay\",\"children\":\"← Back to writing\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"font-mono text-xs uppercase tracking-[0.2em] text-ink/40\",\"children\":[\"2025-12-21\",\" · \",\"3 min read\"]}],[\"$\",\"h1\",null,{\"className\":\"mt-1 text-2xl leading-tight sm:text-3xl\",\"children\":\"2025: What Actually Happened\"}]]}],[\"$\",\"article\",null,{\"className\":\"prose max-w-none prose-headings:text-ink prose-p:text-ink/80 prose-a:text-clay prose-strong:text-ink prose-code:text-clay prose-code:before:content-none prose-code:after:content-none\",\"children\":\"$La\"}]]}]\n8:[[\"$\",\"meta\",\"0\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}],[\"$\",\"meta\",\"1\",{\"charSet\":\"utf-8\"}],[\"$\",\"title\",\"2\",{\"children\":\"Abdihamid Moallim\"}],[\"$\",\"meta\",\"3\",{\"name\":\"description\",\"content\":\"Software engineer. Building web apps, internal tools, and AI-backed products.\"}],[\"$\",\"link\",\"4\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\",\"type\":\"image/x-icon\",\"sizes\":\"150x150\"}],[\"$\",\"link\",\"5\",{\"rel\":\"icon\",\"href\":\"/icon.png?02db24294edd3330\",\"type\":\"image/png\",\"sizes\":\"150x150\"}],[\"$\",\"meta\",\"6\",{\"name\":\"next-size-adjust\"}]]\n1:null\na:[[\"$\",\"h1\",null,{\"children\":\"2025: What Actually Happened\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"At the start of 2025, I had a clear list of goals. Not the loud kind the quiet, personal ones. They came from a year of learning, trying, failing, and slowly understanding myself better.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Now that the year is coming to an end, I want to talk about what actually happened not what looks good on paper, but what stayed.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Learning to Say “No”\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"This one happened. Fully.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I cut a lot of noise from my life this year. Projects, conversations, expectations even people. Not out of arrogance or bitterness, but out of clarity. I learned that saying “yes” to everything was slowly saying “no” to myself.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Life got quieter. And better.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Financial Discipline\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I didn’t suddenly become rich, but I became intentional.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I managed my income more carefully, avoided unnecessary spending, and focused on stability over impulse. That alone reduced a lot of mental stress. Money stopped being something I reacted to and started being something I planned around.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"That shift mattered more than I expected.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"AI Agents (Expectation vs Reality)\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I didn’t go as deep into AI agentics as I thought I would.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"But I also didn’t do nothing.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I built a few agents, experimented, learned the patterns, and understood the limitations. None of them reached production level and I’m okay with that. The learning still happened, just not in the dramatic way I imagined at the start of the year.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":[\"The highlight was the time invested with a friend: we clocked more than 120 focused hours across different agentic projects and we’re currently building \",[\"$\",\"strong\",null,{\"children\":\"Decisionfy\"}],\" together. Sometimes progress is quieter than ambition.\"]}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Lama Tools\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"This was one of the highlights of 2025.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"We delivered seven solid projects, including two AI-enabled semi-ERP systems. Real clients. Real delivery. Real responsibility.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"We may not have hit every financial milestone yet, but Lama Tools moved from “potential” to proven execution and that matters far more in the long run.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Living on My Own Terms\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Alhamdulillah, this one runs deep.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I’ve made peace with who I am, how I work, and what I value. I no longer feel the need to match timelines, expectations, or definitions of success that don’t belong to me.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"That internal peace is something I don’t take lightly.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Content Creation (An Honest Take)\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I tried.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I really did.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"And I realized something important, maybe content creation just isn’t for me or at least not right now. I didn’t enjoy it enough. I didn’t want it badly enough. So I stopped forcing it.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"That felt like growth too.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"Small but Meaningful Tech Shifts\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"This year also had its fun, nerdy transitions:\"}],\"\\n\",[\"$\",\"ul\",null,{\"children\":[\"\\n\",[\"$\",\"li\",null,{\"children\":\"Windows → Linux (Fedora) and I’m genuinely enjoying it\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Cursor → Windsurf\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"OpenAI → Claude\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"pip → uv\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Vercel → Cloudflare\"}],\"\\n\",[\"$\",\"li\",null,{\"children\":\"Chrome → Brave\"}],\"\\n\"]}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Nothing life-changing on its own, but together they reflect a pattern: choosing tools that feel intentional, minimal, and aligned with how I want to work.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"The Biggest Achievement\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"This is the one that outweighs everything else.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"With the help of my sisters and cousin, I managed to move my family from Mogadishu to Kenya.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"No project, no revenue milestone, no technical win comes close to that.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"It was stressful. Heavy. Expensive. Emotional. But it was worth it.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"Alhamdulillah.\"}],\"\\n\",[\"$\",\"h2\",null,{\"children\":\"One More Thing\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"I also spent time learning day trading in a halal way. Not chasing hype, but understanding markets, discipline, risk, and patience. Whether it becomes a long-term path or not, the learning itself has already paid off.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"2025 wasn’t flashy.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"It wasn’t viral.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"It wasn’t loud.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"But it was foundational.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"And I’m walking into the next year calmer, clearer, and more grounded than I’ve ever been.\"}],\"\\n\",[\"$\",\"p\",null,{\"children\":\"That’s enough for now.\"}]]\n"}